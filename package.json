{
  "name": "@manicjs/api-docs",
  "version": "0.2.1",
  "description": "Scalar API docs plugin for Manic framework",
  "keywords": [
    "api",
    "docs",
    "manic",
    "openapi",
    "scalar"
  ],
  "license": "GPL-3.0",
  "author": "Rahuletto",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rahuletto/manic"
  },
  "files": [
    "src/**/*",
    "README.md"
  ],
  "type": "module",
  "main": "./src/index.ts",
